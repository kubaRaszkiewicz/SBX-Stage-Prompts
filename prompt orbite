]

def jd_from_hjd(hjd_str):
    return f"{2400000.0 + float(hjd_str):.3f}" if hjd_str else ""

def make_row(sn, period, period_err, hjd, hjd_err, e, e_err, omega, omega_err,
             K1, K1_err, V, V_err, num1="", num2="", use_note=False,
             asv1="", asv2="", asv1_err="", asv2_err="", K2="", K2_err=""):
    note = NOTE_SENTENCE.format(BIBCODE=BIBCODE) if use_note else ""
    return [
        sn,"",asv1,asv2,asv1_err,asv2_err,BIBCODE,CONTRIBUTOR,
        period and e or e, e_err, "JD","", "", K1, K1_err, K2, K2_err,
        note, num1, num2, "1", omega, omega_err,
        jd_from_hjd(hjd), hjd_err, "0", period, period_err, "", "",
        V, V_err
    ]

def write_orbit(sn, row):
    os.makedirs(OUTPUT_DIR, exist_ok=True)
    path = os.path.join(OUTPUT_DIR, f"orbit_{sn}.csv")
    with open(path, "w", encoding="utf-8") as f:
        f.write(",".join(HEADER) + "\\n")
        f.write(",".join(row) + "\\n")
    return path

